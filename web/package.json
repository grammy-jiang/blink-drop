{
  "name": "blink-drop-web",
  "private": true,
  "version": "0.11.1",
  "type": "module",
  "license": "MIT",
  "description": "Blink-Drop web sender — offline animated-QR file transfer (sender half). See ../docs.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "npm run build && playwright test",
    "mutation": "stryker run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "build:sender": "vite build --config vite.config.sender.ts",
    "gen:vectors": "tsx scripts/gen-vectors.ts",
    "gen:static-qr": "tsx scripts/gen-static-qr.ts",
    "gen:icons": "tsx scripts/gen-icons.ts",
    "sbom": "cyclonedx-npm --omit dev --output-reproducible --output-format JSON --output-file sbom.cdx.json"
  },
  "dependencies": {
    "@ngraveio/bc-ur": "^1.1.13",
    "buffer": "^6.0.3",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "jsqr": "^1.4.0",
    "process": "^0.11.10",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@napi-rs/canvas": "^1.0.2",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.1",
    "@types/qrcode-generator": "^1.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "qs": "6.15.3"
  }
}
